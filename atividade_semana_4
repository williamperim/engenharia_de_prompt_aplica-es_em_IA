import csv

# Nome do arquivo CSV que será lido
arquivo = "dados.csv"

# Nome da coluna que queremos calcular a média
coluna_alvo = "valor"

# Lista para armazenar os valores numéricos
valores = []

# Abrindo o arquivo CSV
with open(arquivo, newline='', encoding='utf-8') as csvfile:
    leitor = csv.DictReader(csvfile)  # Lê cada linha como um dicionário
    for linha in leitor:
        # Converte o valor da coluna para número (float)
        try:
            valor = float(linha[coluna_alvo])
            valores.append(valor)
        except ValueError:
            # Ignora valores inválidos (ex: texto na coluna)
            continue

# Calculando a média
if valores:
    media = sum(valores) / len(valores)
    print(f"A média da coluna '{coluna_alvo}' é: {media:.2f}")
else:
    print("Nenhum valor válido encontrado na coluna.")
